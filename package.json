{
  "name": "rundoc",
  "private": false,
  "version": "0.1.0",
  "description": "AI-Native Markdown Docs for running teams.",
  "type": "module",
  "bin": {
    "rundoc-ai": "./bin/rundoc",
    "rundoc": "./bin/rundoc"
  },
  "files": [
    "bin/",
    "scripts/",
    ".rundoc/config.yml",
    ".rundoc/prompts/",
    ".rundoc/agents/",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/build-docs.mjs",
    "build": "vite build && cp dist/index.html dist/404.html",
    "check:docs": "node scripts/check-docs.mjs",
    "rundoc:init": "node scripts/rundoc.mjs init",
    "rundoc:check": "node scripts/rundoc.mjs check",
    "rundoc:scan": "node scripts/rundoc.mjs scan",
    "rundoc:task": "node scripts/rundoc.mjs task",
    "rundoc:config": "node scripts/rundoc.mjs config",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
