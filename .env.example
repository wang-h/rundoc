# RunID OIDC (unified login for Run series)
RUNID_ISSUER=http://localhost:4100
RUNID_CLIENT_ID=rundoc
RUNID_CLIENT_SECRET=dev-secret-rundoc
RUNID_REDIRECT_URI=http://localhost:5174/auth/callback
RUNID_POST_LOGOUT_REDIRECT_URI=http://localhost:5174
SESSION_SECRET=change-me-in-production
AUTH_MODE=oidc

# RunDoc runtime
RUNDOC_DEFAULT_LOCALE=zh-CN
RUNDOC_SCHEDULE_CADENCE=daily
RUNDOC_SCHEDULE_RUN_AT=09:00
RUNDOC_SCHEDULE_TIMEZONE=Asia/Shanghai

# Vite UI defaults
VITE_DEFAULT_LOCALE=zh-CN
VITE_I18N_MODE=locked
